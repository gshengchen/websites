          "path": "/gshengpath"
        },
        "security": "reality",
        "realitySettings": {
          "target": "www.apple.com:443",
          "serverNames": [
            "www.apple.com"
          ],
          "privateKey": "yMy7K0pUawdAwaJn235XcBjwAriY1uDuangOB5p0eFI",
