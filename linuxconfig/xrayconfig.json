          "tls",
          "quic"
        ],
        "routeOnly": true
      }
    },
    {
      "listen": "0.0.0.0",
      "port": 1507,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "bddd0784-9004-4511-8169-73a56f0d41f0",
