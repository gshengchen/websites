          "serverNames": [
            "www.apple.com"
          ],
          "privateKey": "4NxgINXenAs4fxqH1otPsx376UMZv6rHmDh_JTRczWs",
          "shortIds": [
            "03",
            "0a",
            "0abc",
            "0123456789abcdef"
          ]
        }
      },
      "sniffing": {
