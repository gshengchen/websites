          "geoip:private"
        ],
        "outboundTag": "block"
      },
      {
        "ip": [
          "geoip:cn"
        ],
        "outboundTag": "block"
      },
      {
        "domain": [
          "geosite:category-ads-all"
        ],
        "outboundTag": "block"
      }
    ]
  },
  "inbounds": [
